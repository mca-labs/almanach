---
import Base from '@/layouts/Base.astro';
import {
  entryByDate,
  publishedDates,
  quoteById,
  topBirdsFor,
  weatherFor,
} from '@/lib/queries';

export async function getStaticPaths() {
  const dates = await publishedDates();
  return dates.map((date) => ({ params: { date } }));
}

const { date } = Astro.params as { date: string };
const entry = await entryByDate(date);
if (!entry) {
  // Ne peut pas arriver : getStaticPaths() ne déclare que des dates publiées.
  throw new Error(`Entry not found for ${date} despite being in getStaticPaths.`);
}

const [weather, birds] = await Promise.all([weatherFor(date), topBirdsFor(date, 8)]);
const quoteId = entry.highlights?.fragment_quote_id ?? null;
const quote = quoteId ? await quoteById(quoteId) : null;

function frenchLong(iso: string): string {
  const d = new Date(`${iso}T12:00:00Z`);
  return new Intl.DateTimeFormat('fr-CA', {
    timeZone: 'America/Toronto',
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(d);
}
function paragraphs(md: string | null): string[] {
  if (!md) return [];
  return md.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
}
const body = paragraphs(entry.body_md ?? null);
function fmtTemp(n: number | null | undefined, digits = 1): string {
  return n === null || n === undefined ? '—' : `${n.toFixed(digits)} °C`;
}
function fmtMm(n: number | null | undefined): string {
  return n === null || n === undefined ? '—' : `${n.toFixed(1)} mm`;
}
---

<Base title={`Édition du ${frenchLong(date)}`} active="archives">
  <header class="mast">
    <div class="kicker">
      <span>Archives</span>
      <span><a href="/archives">← toutes les éditions</a></span>
    </div>
    <div class="titleline">
      <h1 class="title">{frenchLong(date)}</h1>
    </div>
    {entry.summary && <p class="condition">{entry.summary}</p>}
  </header>

  <section class="blk billet">
    <div class="rubric"><h2>Billet</h2><span class="line"></span></div>
    {body.map((p, i) => (
      <p class={i === 0 ? 'drop' : ''}>{p}</p>
    ))}
  </section>

  <section class="blk">
    <div class="rubric"><h2>La mesure du jour</h2><span class="line"></span><span class="src">Tempest 41129</span></div>
    <div class="stats">
      <div class="stat"><div class="k">Température</div><div class="v">{fmtTemp(weather?.air_temp_avg ?? null)}</div><div class="sub">min {fmtTemp(weather?.air_temp_min ?? null, 0)} · max {fmtTemp(weather?.air_temp_max ?? null, 0)}</div></div>
      <div class="stat"><div class="k">Pluie</div><div class="v">{fmtMm(weather?.rain_day_final_mm ?? null)}</div><div class="sub">total du jour</div></div>
      <div class="stat"><div class="k">Foudre</div><div class="v">{weather?.lightning_count_total ?? 0}</div><div class="sub">éclair(s)</div></div>
      <div class="stat"><div class="k">Détections</div><div class="v">{birds.reduce((acc, b) => acc + b.count, 0)}</div><div class="sub">{birds.length} espèces (top)</div></div>
    </div>
  </section>

  {quote && (
    <section class="blk">
      <div class="rubric mini"><h2>Fragment</h2><span class="line"></span></div>
      <blockquote class="frag">
        « {quote.text} »
        <cite>{quote.author} — {quote.work}{quote.year ? `, ${quote.year}` : ''}</cite>
      </blockquote>
    </section>
  )}
</Base>
