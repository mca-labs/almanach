---
import Base from '@/layouts/Base.astro';
import Footer from '@/components/Footer.astro';
import ebirdCodes from '../../../data/ebird-species-codes.json';
import {
  birdOfTheDayWithPhoto,
  birdsFor,
  birdsSeries,
  latestPublished,
  publishedDates,
  quoteById,
  randomQuote,
  rareSpeciesForDate,
  skyForEntry,
  topBirdsWithPhotos,
  weatherFor,
  type SkyEvent,
} from '@/lib/data';

const entry = await latestPublished();
const allDates = await publishedDates();
const previousDate = entry ? allDates.find((d) => d < entry.entry_date) : null;

const date = entry?.entry_date ?? null;
const [weather, birds, sky, topBirds, birdPhoto, rareSpecies] = date
  ? await Promise.all([
      weatherFor(date),
      birdsFor(date),
      skyForEntry(date),
      topBirdsWithPhotos(date, 8),
      birdOfTheDayWithPhoto(date),
      rareSpeciesForDate(date),
    ])
  : [null, null, null, [], null, []];

const quoteId = entry?.fragment_quote_id ?? null;
const quote = quoteId ? await quoteById(quoteId) : null;

const birdSeries = date ? await birdsSeries(date, 30) : [];

// État « aucune édition » : une citation au hasard pour clore l'écran d'attente.
const emptyQuote = entry === null ? await randomQuote() : null;

// --- Helpers ---
const TZ = 'America/Toronto';
function frenchDateLine(iso: string): { hier: string; ed: string } {
  const d = new Date(`${iso}T12:00:00Z`);
  const long = new Intl.DateTimeFormat('fr-CA', { timeZone: TZ, weekday: 'long', day: 'numeric', month: 'long' }).format(d);
  const year = d.getUTCFullYear();
  const startOfYear = Date.UTC(year, 0, 1);
  const doy = Math.floor((d.getTime() - startOfYear) / 86400000) + 1;
  return { hier: long, ed: `an ${year} · ${doy}ᵉ jour` };
}
function frenchSkyDate(iso: string): string {
  const d = new Date(`${iso}T12:00:00Z`);
  return new Intl.DateTimeFormat('fr-CA', { timeZone: TZ, day: 'numeric', month: 'long', year: 'numeric' }).format(d);
}
function paragraphs(md: string | null): string[] {
  if (!md) return [];
  return md.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
}
// Échappe le HTML : le texte vient du LLM (et de données tierces) ; on n'injecte
// comme HTML réel que les <em> qu'on ajoute nous-mêmes, jamais le texte source.
function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function renderItalics(text: string, taxons: string[] = []): { html: string }[] {
  // 1. Auto-wrap les binômes latins (liste blanche depuis les taxons réels du jour)
  //    en *...* s'ils ne sont pas déjà entourés. Évite les faux positifs sur des
  //    expressions françaises type "La paruline" ou "Jupiter resteront".
  let processed = text;
  for (const taxon of taxons) {
    if (!taxon) continue;
    const escaped = taxon.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const re = new RegExp(`(?<!\\*)\\b${escaped}\\b(?!\\*)`, 'g');
    processed = processed.replace(re, `*${taxon}*`);
  }
  // 2. Découpe sur les motifs *...* pour rendre les noms latins en italique.
  const parts = processed.split(/(\*[^*\n]+\*)/g);
  return parts
    .filter(Boolean)
    .map((p) =>
      p.startsWith('*') && p.endsWith('*')
        ? { html: `<em>${escapeHtml(p.slice(1, -1))}</em>` }
        : { html: escapeHtml(p) },
    );
}
function fmtTimeIso(iso: string | null | undefined): string {
  if (!iso) return '—';
  return new Intl.DateTimeFormat('fr-CA', { timeZone: TZ, hour: '2-digit', minute: '2-digit' }).format(new Date(iso));
}
function fmtMm(n: number | null | undefined): string { return n === null || n === undefined ? '—' : `${n.toFixed(1)}`; }
const EBIRD_CODES = ebirdCodes as Record<string, string>;
function ebirdUrl(taxon_scientific: string | null | undefined): string | null {
  if (!taxon_scientific) return null;
  const code = EBIRD_CODES[taxon_scientific];
  return code ? `https://ebird.org/species/${code}?lang=fr` : null;
}
function pressureArrow(dir: 'up' | 'down' | 'flat' | null | undefined): string {
  return dir === 'up' ? '↗' : dir === 'down' ? '↘' : dir === 'flat' ? '→' : '';
}
function pressureLabel(dir: 'up' | 'down' | 'flat' | null | undefined): string {
  return dir === 'up' ? 'en hausse' : dir === 'down' ? 'en baisse' : dir === 'flat' ? 'stable' : '';
}
/** Bargraph lux : 24 rects (un par heure) sur viewbox 660×100, position du pic pour l'icône soleil. */
function luxBars(hourly: (number | null)[] | undefined):
  | {
      rects: { x: number; y: number; w: number; h: number; hour: number; lux: number; isPeak: boolean }[];
      peak: { x: number; y: number; hour: number; lux: number } | null;
    }
  | null {
  if (!hourly || hourly.length !== 24) return null;
  const vals = hourly.map((v) => v ?? 0);
  const max = Math.max(...vals, 1);
  const VBW = 660;
  const VBH = 100;
  const TOP = 12; // espace pour l'icône soleil
  const BOTTOM = 2;
  const GAP = 2;
  const slot = VBW / 24;
  const w = Math.max(slot - GAP, 1);
  // Index du pic
  let peakIdx = 0;
  for (let i = 1; i < vals.length; i++) if (vals[i]! > vals[peakIdx]!) peakIdx = i;
  const rects = vals.map((v, i) => {
    const h = (v / max) * (VBH - TOP - BOTTOM);
    const x = i * slot + GAP / 2;
    const y = VBH - BOTTOM - h;
    return { x, y, w, h, hour: i, lux: v, isPeak: i === peakIdx && v > 0 };
  });
  const peakRect = rects[peakIdx]!;
  const peak = peakRect.lux > 0
    ? { x: peakRect.x + peakRect.w / 2, y: peakRect.y, hour: peakIdx, lux: peakRect.lux }
    : null;
  return { rects, peak };
}

/** Compte les heures par état de ciel (basé sur lux moyen horaire). Heures de nuit exclues. */
function luxHoursByState(hourly: (number | null)[] | undefined):
  { plein: number; voilé: number; couvert: number } {
  const out = { plein: 0, voilé: 0, couvert: 0 };
  if (!hourly) return out;
  for (const v of hourly) {
    if (v == null || v < 1000) continue; // nuit / crépuscule : exclus
    if (v >= 50000) out.plein += 1;
    else if (v >= 10000) out.voilé += 1;
    else out.couvert += 1;
  }
  return out;
}

function stormAgeLabel(daysAgo: number): string {
  // Le site adopte la perspective du lecteur (qui lit le lendemain matin).
  // days_ago = 0 = orage le jour de l'édition = hier pour le lecteur.
  const d = daysAgo + 1;
  if (d === 1) return "hier";
  if (d === 2) return "avant-hier";
  if (d < 30) return `il y a ${d} jours`;
  if (d < 90) return `il y a ${Math.round(d / 7)} semaines`;
  return '+3 mois';
}
function stormDistanceLabel(daysAgo: number, km: number | null): string {
  if (daysAgo + 1 >= 90 || km === null) return '';
  return `, à ${Math.round(km)} km`;
}
function pressureDeltaFmt(t: number | null | undefined): string {
  if (t === null || t === undefined) return '';
  const sign = t > 0 ? '+' : '';
  // Virgule décimale française + espace insécable devant l'unité
  return `${sign}${t.toFixed(1).replace('.', ',')} hPa / 3 h`;
}
function capitalize(s: string): string {
  return s.length > 0 ? s.charAt(0).toUpperCase() + s.slice(1) : s;
}
function fmtKmh(ms: number | null | undefined): string { return ms === null || ms === undefined ? '—' : (ms * 3.6).toFixed(1); }
function dayDuration(sunrise: string | null, sunset: string | null): string {
  if (!sunrise || !sunset) return '—';
  const ms = new Date(sunset).getTime() - new Date(sunrise).getTime();
  const h = Math.floor(ms / 3600000);
  const m = Math.floor((ms % 3600000) / 60000);
  return `${h} h ${String(m).padStart(2, '0')}`;
}
/** Convertit un ISO en heure-fraction locale (ex. 04:56 → 4.93). */
function hourFraction(iso: string | null | undefined): number | null {
  if (!iso) return null;
  const fmt = new Intl.DateTimeFormat('en-CA', { timeZone: TZ, hour: '2-digit', minute: '2-digit', hour12: false });
  const parts = fmt.formatToParts(new Date(iso));
  const h = Number(parts.find((p) => p.type === 'hour')?.value ?? 0);
  const m = Number(parts.find((p) => p.type === 'minute')?.value ?? 0);
  return h + m / 60;
}

function findEvent(category: SkyEvent['category']): SkyEvent | undefined {
  return sky?.events.find((e) => e.category === category);
}
const twilight = findEvent('twilight');
const twDetail = (twilight?.detail ?? {}) as { sunrise?: string | null; sunset?: string | null };
const moon = findEvent('moon');
const moonDetail = (moon?.detail ?? {}) as { illumination_fraction?: number; set?: string | null };
const notablePlanets = (sky?.events ?? []).filter((e) => e.category === 'planet' && e.notable);

const dateLine = date ? frenchDateLine(date) : null;
const pageTitle = 'Almanach du Val-des-Loups - Saint-Placide-de-Charlevoix';
const body = paragraphs(entry?.body_md ?? null);

const birdName = birdPhoto?.name_fr ?? birdPhoto?.taxon_common ?? birdPhoto?.taxon_scientific ?? '—';
const obsBirdUrl = ebirdUrl(birdPhoto?.taxon_scientific);

// Liste blanche des binômes latins du jour pour l'auto-italique (renderItalics).
const dayTaxons: string[] = Array.from(new Set([
  ...(birds?.top_species ?? []).map((s) => s.taxon_scientific).filter(Boolean),
  birdPhoto?.taxon_scientific,
  birds?.bird_of_the_day?.taxon_scientific,
].filter((t): t is string => !!t)));

// --- Données pour les SVG (réelles, agrégées server-side) ---
const TEMP_HOURS: (number | null)[] = weather?.hourly_temps_c ?? new Array(24).fill(null);
const TEMP_NORM: (number | null)[] = weather?.hourly_norm_c ?? [];
const BIRD_HOURS: number[] = birds?.hourly_detections ?? new Array(24).fill(0);
// Série 30 jours pour le graphique « Observations & espèces ».
const fmtDayMonth = new Intl.DateTimeFormat('fr-CA', { timeZone: TZ, day: 'numeric', month: 'short' });
const BIRD_SERIES = {
  det: birdSeries.map((p) => p.total_detections),
  spe: birdSeries.map((p) => p.unique_species),
  labels: birdSeries.map((p) => fmtDayMonth.format(new Date(`${p.date}T12:00:00Z`))),
};
const SUNRISE_H: number = hourFraction(twDetail.sunrise) ?? 5;
const SUNSET_H: number = hourFraction(twDetail.sunset) ?? 20;
const LUX_PEAK_HOUR: number | null = weather?.lux_peak?.hour ?? null;
const LUX_PEAK_VALUE: number | null = weather?.lux_peak?.value_lux ?? null;
// Mappage lux → pourcentage de jauge : 0 → 0 %, ~55 000 lux (plein soleil voilé) → 100 %.
const LUX_PEAK_PCT: number = LUX_PEAK_VALUE !== null ? Math.max(0, Math.min(100, LUX_PEAK_VALUE / 550)) : 0;
---

<Base title={pageTitle} active="une">
  {entry === null ? (
    <header class="mast empty">
      <div class="kicker">
        <span>Pont couvert de Saint-Placide-de-Charlevoix</span>
        <span><a href="https://maps.app.goo.gl/im6WzdgPWXcfj9Nx5" target="_blank" rel="noopener">47,4° N · 70,6° O · 377 m</a></span>
      </div>
      <h1 class="empty-title">Aucune édition disponible présentement, travaux en cours</h1>
      <p class="empty-body">
        L’Almanach du Val-des-Loups est le journal naturaliste quotidien de la forêt près du
        pont couvert de Saint-Placide-de-Charlevoix.
      </p>
      <p class="empty-body">
        Chaque nuit, l’IA rédige une nouvelle édition pour raconter les événements de la veille à
        partir de capteurs automatisés installés autour de la propriété. Les éphémérides
        astronomiques, elles, regardent vers l’avant — elles parlent de la nuit à venir pour
        permettre de planifier les observations.
      </p>
      {emptyQuote && (
        <blockquote class="frag empty-quote">
          « {emptyQuote.text} »
          <cite>{emptyQuote.author} — {emptyQuote.work}{emptyQuote.year ? `, ${emptyQuote.year}` : ''}</cite>
        </blockquote>
      )}
    </header>
  ) : (
    <>
      {/* EN-TÊTE */}
      <header class="mast rv" style="animation-delay:.02s">
        <div class="kicker">
          <span>Pont couvert de Saint-Placide-de-Charlevoix</span>
          <span><a href="https://maps.app.goo.gl/im6WzdgPWXcfj9Nx5" target="_blank" rel="noopener">47,4° N · 70,6° O · 377 m</a></span>
        </div>
        <div class="titleline">
          <h1 class="title"><em>Hier,</em> {dateLine?.hier}</h1>
          <span class="ed">{dateLine?.ed}</span>
        </div>
        {entry.summary && (
          <p class="condition">
            {renderItalics(entry.summary, dayTaxons).map((fr) => (<Fragment set:html={fr.html} />))}
          </p>
        )}
      </header>

      {/* BILLET */}
      <section class="blk rv billet" style="animation-delay:.08s">
        <div class="rubric">
          <h2>Billet</h2><span class="line"></span>
        </div>
        {body.map((p, i) => (
          <p class={i === 0 ? 'drop' : ''}>
            {renderItalics(p, dayTaxons).map((fr) => (<Fragment set:html={fr.html} />))}
          </p>
        ))}
        {previousDate && <p class="more"><a href="/archives">Éditions précédentes →</a></p>}
      </section>

      {/* OBSERVATION DU JOUR */}
      {birdPhoto && (
        <section class="blk rv" style="animation-delay:.14s">
          <div class="rubric">
            <h2>Observation du jour</h2><span class="line"></span>
            <span class="src"><a href="https://app.birdweather.com/stations/6670" target="_blank" rel="noopener">BirdWeather PUC</a></span>
          </div>
          <div class="obs">
            {birdPhoto.photo_url ? (
              <div class="photo" style="padding:0;overflow:hidden" title={birdPhoto.attribution ?? undefined}>
                {obsBirdUrl ? (
                  <a href={obsBirdUrl} target="_blank" rel="noopener" style="display:block;width:100%;height:100%">
                    <img src={birdPhoto.photo_url} alt={`Photo de référence : ${birdName}`} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block" />
                  </a>
                ) : (
                  <img src={birdPhoto.photo_url} alt={`Photo de référence : ${birdName}`} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block" />
                )}
              </div>
            ) : (
              <div class="photo">
                <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#6E766F" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h.01M3.4 18c-.6-1.1-.9-2.4-.9-3.7C2.5 9.2 6 5.5 10.5 5.5c3.8 0 6.3 2.4 7 5.5l1.5 1.2c.3.2.5.5.5.9 0 .5-.4.9-.9.9H16l-2 6.5-3-3.5-2 2.5c-2.8 0-4.2-2-5.6-1.5Z"/></svg>
                <span class="cap">image de référence</span>
              </div>
            )}
            <div>
              <div class="sp">
                {obsBirdUrl ? <a href={obsBirdUrl} target="_blank" rel="noopener">{birdName}</a> : birdName}
              </div>
              {birdPhoto.taxon_scientific && <div class="lat">{birdPhoto.taxon_scientific}</div>}
              <div class="meta">
                {birdPhoto.observed_at && <span>entendue à {fmtTimeIso(birdPhoto.observed_at)}</span>}
                {birdPhoto.confidence !== null && birdPhoto.confidence !== undefined && (
                  <span class="pill">confiance {Math.round(birdPhoto.confidence * 100)}&nbsp;%</span>
                )}
              </div>
              {birdPhoto.media_url && (
                <div class="player">
                  <button class="listen" id="listenBtn" type="button" aria-label="Écouter l'enregistrement" data-audio-src={birdPhoto.media_url}>
                    <svg class="i-play" width="11" height="11" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>
                    <svg class="i-pause" width="11" height="11" viewBox="0 0 24 24" aria-hidden="true" hidden><path fill="currentColor" d="M7 5h3.4v14H7zM13.6 5H17v14h-3.4z"/></svg>
                    <span class="listen-lbl">Écouter</span>
                  </button>
                  <div class="pwrap" id="pwrap" hidden>
                    <div class="pbar" id="pbar" role="slider" aria-label="Position de lecture" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0">
                      <div class="pbar-fill" id="pbarFill"></div>
                    </div>
                    <span class="ptime" id="ptime">0:00&#8201;/&#8201;0:00</span>
                  </div>
                  <audio id="obsAudio" preload="none" crossorigin="anonymous"></audio>
                </div>
              )}
            </div>
          </div>
        </section>
      )}

      {/* ACTIVITÉS DES OISEAUX — horloge 24h */}
      <section class="blk rv" style="animation-delay:.32s">
        <div class="rubric">
          <h2>Activités des oiseaux</h2><span class="line"></span>
          <span class="src"><a href="https://app.birdweather.com/stations/6670" target="_blank" rel="noopener">BirdWeather</a> · sur 24&nbsp;h</span>
        </div>
        <div class="vizt">
          <div class="item">
            <div class="num">{birds?.unique_species ?? 0}</div>
            <div class="lbl">espèces</div>
          </div>
          <div class="sep" aria-hidden="true"></div>
          <div class="item">
            <div class="num">{(birds?.total_detections ?? 0).toLocaleString('fr-CA')}</div>
            <div class="lbl">détections</div>
          </div>
        </div>
        <div class="plate clockwrap">
          <div class="ctip" id="ctip"></div>
          <svg id="clock" viewBox="-20 -20 340 340" width="100%" style="max-width:330px" role="img" aria-label="Activité des oiseaux par heure en horloge 24h."></svg>
          <div class="clocklegend">
            <span><span class="d" style="background:var(--ink)"></span>détections / heure</span>
            <span><span class="d" style="background:var(--teal)"></span>jour</span>
            <span><span class="d" style="background:#D8D2C6"></span>nuit</span>
          </div>
        </div>

        {birdSeries.length > 1 && (
          <div class="bseries">
            <div class="rubric mini">
              <h2>Observations &amp; espèces</h2><span class="line"></span>
              <span class="src">sur {birdSeries.length}&nbsp;jours</span>
            </div>
            <div class="bswrap">
              <div class="bstip" id="bstip"></div>
              <div class="bsscroll" id="bsscroll">
                <svg id="bsvg" viewBox="0 0 660 170" role="img" aria-label={`Observations et espèces par jour sur ${birdSeries.length} jours`}></svg>
              </div>
            </div>
            <div class="bslegend">
              <span><span class="sw"></span>observations / jour</span>
              <span><span class="swl"></span>espèces / jour</span>
            </div>
          </div>
        )}
      </section>

      {/* LES OISEAUX DU JOUR */}
      <section class="blk rv flush" style="animation-delay:.38s">
        <details class="drawer" open>
          <summary>Visiteurs les plus fréquents aujourd'hui <span class="chev">▾</span></summary>
          <div class="drawerbody">
            <svg width="0" height="0" style="position:absolute" aria-hidden="true"><symbol id="bird" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" d="M16 7h.01M3.4 18c-.6-1.1-.9-2.4-.9-3.7C2.5 9.2 6 5.5 10.5 5.5c3.8 0 6.3 2.4 7 5.5l1.5 1.2c.3.2.5.5.5.9 0 .5-.4.9-.9.9H16l-2 6.5-3-3.5-2 2.5c-2.8 0-4.2-2-5.6-1.5Z"/></symbol></svg>
            <div class="bgrid">
              {topBirds.map((b) => {
                const name = b.name_fr ?? b.taxon_common ?? b.taxon_scientific;
                const url = ebirdUrl(b.taxon_scientific);
                return (
                  <div class="bird">
                    <div class="bphoto" title={b.attribution ?? undefined} style={b.photo_url ? 'padding:0;overflow:hidden' : ''}>
                      {b.photo_url ? (
                        url ? (
                          <a href={url} target="_blank" rel="noopener" style="display:block;width:100%;height:100%">
                            <img src={b.photo_url} alt={`Photo : ${name}`} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block" />
                          </a>
                        ) : (
                          <img src={b.photo_url} alt={`Photo : ${name}`} loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block" />
                        )
                      ) : (
                        <svg><use href="#bird"/></svg>
                      )}
                    </div>
                    <div class="bname">
                      {url ? <a href={url} target="_blank" rel="noopener">{name}</a> : name}
                      <i>{b.taxon_scientific}</i>
                      <span style="display:block;font-style:normal;color:var(--ink-3);font-size:11.5px;margin-top:1px">{b.count} observation{b.count > 1 ? 's' : ''}</span>
                    </div>
                  </div>
                );
              })}
            </div>
            <div class="rare">
              <b>Premières de la saison :</b>{' '}
              {rareSpecies.length > 0 ? (
                <>
                  {rareSpecies.map((s, i) => {
                    const rname = s.name_fr ?? s.taxon_common ?? s.taxon_scientific;
                    const rurl = ebirdUrl(s.taxon_scientific);
                    return (
                    <>
                      {i > 0 ? ' · ' : ''}
                      <span class="rarebird" title={s.attribution ?? undefined} tabindex={rurl ? undefined : 0}>
                        {rurl ? <a href={rurl} target="_blank" rel="noopener">{rname}</a> : rname}
                        <span class="bzoom">
                          {s.photo_url ? (
                            <img src={s.photo_url} alt={`Photo : ${s.name_fr ?? s.taxon_scientific}`} loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:10px" />
                          ) : (
                            <svg><use href="#bird"/></svg>
                          )}
                        </span>
                      </span>
                    </>
                    );
                  })}
                  .{' '}
                </>
              ) : (
                <span>aucune nouvelle espèce.{' '}</span>
              )}
              &nbsp;<a href="https://app.birdweather.com/stations/6670" target="_blank" rel="noopener">Voir toutes les espèces sur BirdWeather →</a>
            </div>
          </div>
        </details>
      </section>

      {/* MÉTÉO + LUMINOSITÉ */}
      <section class="blk rv" style="animation-delay:.44s">
        <div class="rubric">
          <h2>Météo</h2><span class="line"></span>
          <span class="src"><a href="https://tempestwx.com/station/41129/" target="_blank" rel="noopener">Station météo Tempest</a></span>
        </div>
        <div class="stats">
          <div class="stat">
            <div class="k">Vent</div>
            {weather?.wind ? (
              <>
                <div class="v">{capitalize(weather.wind.qualifier ?? '—')}</div>
                {weather.wind.qualifier !== 'calme plat' && weather.wind.direction_label && (
                  <div class="sub">
                    {weather.wind.direction_label} à {Math.round(weather.wind.avg_kmh ?? 0)}&nbsp;km/h
                  </div>
                )}
                {weather.wind.gust_max_kmh != null && weather.wind.gust_max_kmh > 0 && (
                  <div class="sub">
                    rafale {Math.round(weather.wind.gust_max_kmh)}&nbsp;km/h
                    {weather.wind.gust_max_hour_local !== null
                      ? <> vers {String(weather.wind.gust_max_hour_local).padStart(2, '0')}&nbsp;h</>
                      : ''}
                  </div>
                )}
              </>
            ) : (
              <>
                <div class="v">{fmtKmh(weather?.wind_avg_avg_ms)}&nbsp;<small>km/h</small></div>
                <div class="sub">rafale max {fmtKmh(weather?.wind_gust_max_ms)}&nbsp;km/h</div>
              </>
            )}
          </div>
          <div class="stat">
            <div class="k">Pluie 24&nbsp;h</div>
            <div class="v">{fmtMm(weather?.rain_day_final_mm)}&nbsp;<small>mm</small></div>
            {weather?.rain_week_total_mm != null ? (
              <div class="sub">{weather.rain_week_total_mm.toFixed(1).replace('.', ',')}&nbsp;mm depuis une semaine</div>
            ) : (
              (weather?.rain_day_final_mm ?? 0) === 0 && <div class="sub">sec</div>
            )}
          </div>
          <div class="stat">
            <div class="k">Pression</div>
            {weather?.pressure?.mb_now != null ? (
              <>
                <div class="v">{capitalize(weather.pressure.category ?? '—')}</div>
                <div class="sub">
                  {`${Math.round(weather.pressure.mb_now)} hPa${
                    weather.pressure.direction
                      ? `, ${pressureArrow(weather.pressure.direction)} ${pressureLabel(weather.pressure.direction)}`
                      : ''
                  }`}
                </div>
                {weather.pressure.trend_3h_mb != null && (
                  <div class="sub">{pressureDeltaFmt(weather.pressure.trend_3h_mb)}</div>
                )}
              </>
            ) : (
              <>
                <div class="v">—</div>
                <div class="sub">à venir</div>
              </>
            )}
          </div>
          <div class="stat">
            <div class="k">Dernier orage</div>
            {weather?.lightning.last_storm ? (
              <>
                <div class="v">
                  {weather.lightning.last_storm.count}&nbsp;<small>éclair{weather.lightning.last_storm.count === 1 ? '' : 's'}</small>
                </div>
                <div class="sub">
                  {stormAgeLabel(weather.lightning.last_storm.days_ago)}{stormDistanceLabel(weather.lightning.last_storm.days_ago, weather.lightning.last_storm.avg_distance_km)}
                </div>
              </>
            ) : weather?.lightning.count_total ? (
              // Fallback éditions sans last_storm (anciens fichiers data/weather/)
              <>
                <div class="v">{weather.lightning.count_total}&nbsp;<small>éclair{weather.lightning.count_total === 1 ? '' : 's'}</small></div>
                <div class="sub">aujourd’hui</div>
              </>
            ) : (
              <>
                <div class="v">—</div>
                <div class="sub">aucun récent</div>
              </>
            )}
          </div>
        </div>

        <figure class="plate">
          <div class="ttip" id="temptip"></div>
          <div class="legendrow">
            <span><span class="sw" style="border-top-color:var(--accent)"></span>cette année</span>
            <span><span class="sw" style="border-top-color:var(--ink-3);border-top-style:dashed"></span>moyenne historique, même date</span>
          </div>
          <svg id="temp" viewBox="0 0 660 170" width="100%" role="img" aria-label="Température sur 24 heures."></svg>
          <figcaption><span>température sur 24&nbsp;h</span><span>min {weather?.air_temp_min_c?.toFixed(0) ?? '—'}&nbsp;°C · max {weather?.air_temp_max_c?.toFixed(0) ?? '—'}&nbsp;°C</span></figcaption>
        </figure>

        <div class="gauge">
          <div class="rubric mini">
            <h2>Luminosité</h2><span class="line"></span>
          </div>
          {(() => {
            const bars = luxBars(weather?.hourly_lux_avg);
            return bars ? (
              <div class="luxwrap">
                <div class="lbtip" id="lbtip"></div>
                <svg class="luxbars" viewBox="0 0 660 100" preserveAspectRatio="none" role="img" aria-label="Luminosité moyenne par heure (24 h)">
                  {bars.rects.map((r) => (
                    <rect x={r.x.toFixed(1)} y={r.y.toFixed(1)} width={r.w.toFixed(1)} height={r.h.toFixed(1)} fill="var(--accent)" fill-opacity={r.isPeak ? 0.7 : 0.32} data-tip={r.lux > 0 ? `${String(r.hour).padStart(2, '0')} h : ${Math.round(r.lux).toLocaleString('fr-CA')} lux${r.isPeak ? ' — pic du jour' : ''}` : ''}></rect>
                  ))}
                  {bars.peak && (
                    <g transform={`translate(${bars.peak.x.toFixed(1)} ${(bars.peak.y - 7).toFixed(1)})`} stroke="var(--accent)" stroke-width="0.9" stroke-linecap="round">
                      <circle cx="0" cy="0" r="2.4" fill="var(--accent)" stroke="none"/>
                      <line x1="-4.5" y1="0" x2="-3" y2="0"/>
                      <line x1="3" y1="0" x2="4.5" y2="0"/>
                      <line x1="0" y1="-4.5" x2="0" y2="-3"/>
                      <line x1="0" y1="3" x2="0" y2="4.5"/>
                      <line x1="-3.2" y1="-3.2" x2="-2.2" y2="-2.2"/>
                      <line x1="2.2" y1="2.2" x2="3.2" y2="3.2"/>
                      <line x1="-3.2" y1="3.2" x2="-2.2" y2="2.2"/>
                      <line x1="2.2" y1="-2.2" x2="3.2" y2="-3.2"/>
                    </g>
                  )}
                </svg>
              </div>
            ) : (
              <div class="luxbars-fallback">—</div>
            );
          })()}
          <div class="sun">
            <span class="seg">
              <svg class="ico" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v8"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m8 6 4-4 4 4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>
              Lever <b>{fmtTimeIso(twDetail.sunrise)}</b>
            </span>
            <span class="seg">
              <svg class="ico" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 10V2"/><path d="m4.93 10.93 1.41 1.41"/><path d="M2 18h2"/><path d="M20 18h2"/><path d="m19.07 10.93-1.41 1.41"/><path d="M22 22H2"/><path d="m16 6-4 4-4-4"/><path d="M16 18a4 4 0 0 0-8 0"/></svg>
              Coucher <b>{fmtTimeIso(twDetail.sunset)}</b>
            </span>
            <span class="seg">
              <svg class="ico" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              Durée du jour <b>{dayDuration(twDetail.sunrise ?? null, twDetail.sunset ?? null)}</b>
            </span>
          </div>
          {(() => {
            const hours = luxHoursByState(weather?.hourly_lux_avg);
            const segs = [
              hours.plein > 0 ? { n: hours.plein, label: 'plein soleil' } : null,
              hours.voilé > 0 ? { n: hours.voilé, label: 'voilé' } : null,
              hours.couvert > 0 ? { n: hours.couvert, label: 'couvert' } : null,
            ].filter(Boolean) as { n: number; label: string }[];
            return segs.length > 0 ? (
              <div class="lux-states">
                {segs.map((s) => (
                  <span class="seg"><b>{s.n} h</b> {s.label}</span>
                ))}
              </div>
            ) : null;
          })()}
        </div>
      </section>

      {/* ÉPHÉMÉRIDES */}
      <section class="blk rv" style="animation-delay:.46s">
        <div class="rubric">
          <h2>Éphémérides : ce soir, le {sky ? frenchSkyDate(sky.for_date) : '—'}</h2><span class="line"></span>
          <span class="src">almanach · astronomy-engine</span>
        </div>
        <div class="sky">
          {moon && (
            <span class="it">
              <svg width="17" height="17" viewBox="0 0 24 24"><path d="M12 3a9 9 0 1 0 9 9 7 7 0 0 1-9-9Z" fill="#3F6764"/></svg>
              {moon.title}{moonDetail.illumination_fraction !== undefined ? `, ${Math.round(moonDetail.illumination_fraction * 100)} %` : ''}{moonDetail.set ? ` — couchée à ${fmtTimeIso(moonDetail.set)}` : ''}
            </span>
          )}
          {notablePlanets.length > 0 && (
            <span class="it">
              <svg width="17" height="17" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5" fill="none" stroke="#3F6764" stroke-width="1.6"/><ellipse cx="12" cy="12" rx="9" ry="3.4" fill="none" stroke="#3F6764" stroke-width="1.2" transform="rotate(-20 12 12)"/></svg>
              {notablePlanets.map((p) => p.title).join(', ')}, basses à l'ouest dès la tombée du jour
            </span>
          )}
          {twDetail.sunset && (
            <span class="it">
              <svg width="17" height="17" viewBox="0 0 24 24"><path d="M5 19l3-7 3 5 2-9 3 11" fill="none" stroke="#6E766F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Coucher du soleil {fmtTimeIso(twDetail.sunset)}
            </span>
          )}
        </div>
        {entry.sky_narrative && (
          <p class="propice">
            {renderItalics(entry.sky_narrative, dayTaxons).map((fr) => (<Fragment set:html={fr.html} />))}
          </p>
        )}
      </section>

      {/* FRAGMENT */}
      {quote && (
        <section class="blk rv" style="animation-delay:.52s">
          <div class="rubric">
            <h2>Fragment</h2><span class="line"></span>
          </div>
          <blockquote class="frag">
            « {quote.text} »
            {entry.fragment_translation_fr && (
              <span style="display:block;margin-top:8px;font-size:.92em;color:var(--ink-2)">
                « {entry.fragment_translation_fr} »
              </span>
            )}
            <cite>{quote.author} — {quote.work}{quote.year ? `, ${quote.year}` : ''}</cite>
          </blockquote>
        </section>
      )}

      <Footer />
    </>
  )}

  <script
    is:inline
    define:vars={{ TEMP_HOURS, TEMP_NORM, BIRD_HOURS, SUNRISE_H, SUNSET_H, BIRD_SERIES }}
  >
    /* Script reconduit du mockup une.html (TEMP_HOURS/TEMP_NORM/BIRD_HOURS/SUNRISE_H/SUNSET_H injectés). */
    (function () {
      // ---- Courbe de température : cette année vs moyenne historique (si dispo) ----
      var year = TEMP_HOURS.map(function (v) { return v === null ? null : v; });
      var norm = TEMP_NORM;
      // bornes de l'axe — basées sur les vraies données + un peu de marge
      var defined = year.filter(function (v) { return v !== null; }).concat(norm.filter(function (v) { return v !== null; }));
      var tmin = defined.length ? Math.floor(Math.min.apply(null, defined) - 2) : -2;
      var tmax = defined.length ? Math.ceil(Math.max.apply(null, defined) + 2) : 22;
      var W = 660, H = 170, padL = 8, padR = 8, padT = 14, padB = 22;
      function X(i) { return padL + (i / 23) * (W - padL - padR); }
      function Y(t) { return padT + (1 - (t - tmin) / (tmax - tmin)) * (H - padT - padB); }
      function poly(a) {
        // tolère des null : on coupe la polyligne en segments
        var segs = [], cur = [];
        for (var i = 0; i < a.length; i++) {
          if (a[i] === null) { if (cur.length) { segs.push(cur); cur = []; } }
          else { cur.push(X(i).toFixed(1) + ',' + Y(a[i]).toFixed(1)); }
        }
        if (cur.length) segs.push(cur);
        return segs.map(function (s) { return s.join(' '); });
      }
      var g = '<rect x="0" y="0" width="' + W + '" height="' + H + '" fill="transparent" pointer-events="all"/>';
      // grille + labels d'axe
      var ticks = [];
      var step = Math.max(5, Math.round((tmax - tmin) / 4));
      for (var t = Math.ceil(tmin / step) * step; t <= tmax; t += step) ticks.push(t);
      ticks.forEach(function (t) {
        g += '<line x1="' + padL + '" y1="' + Y(t).toFixed(1) + '" x2="' + (W - padR) + '" y2="' + Y(t).toFixed(1) + '" stroke="rgba(43,55,54,.10)" stroke-width="1"/>';
        g += '<text x="' + (W - padR) + '" y="' + (Y(t) - 4).toFixed(1) + '" text-anchor="end" font-family="Spectral,serif" font-size="11" fill="#6E766F">' + t + '°</text>';
      });
      // moyenne historique (dashed) — uniquement si on a des valeurs
      if (norm.length) {
        poly(norm).forEach(function (pts) {
          g += '<polyline fill="none" stroke="#6E766F" stroke-width="1.4" stroke-dasharray="2 4" points="' + pts + '"/>';
        });
      }
      // courbe de l'année
      poly(year).forEach(function (pts) {
        g += '<polyline fill="none" stroke="#3F6764" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round" points="' + pts + '"/>';
      });
      ['00h', '06h', '12h', '18h'].forEach(function (l, k) {
        var i = k * 6;
        g += '<text x="' + X(i).toFixed(1) + '" y="' + (H - 6) + '" text-anchor="middle" font-family="Spectral,serif" font-size="11" fill="#6E766F">' + l + '</text>';
      });
      g += '<line id="tgl" x1="0" y1="' + padT + '" x2="0" y2="' + (H - padB) + '" stroke="#3F6764" stroke-width="1" opacity="0"/>';
      g += '<circle id="tgd" r="3.6" fill="#3F6764" opacity="0"/>';
      var tsvg = document.getElementById('temp');
      if (tsvg) {
        tsvg.innerHTML = g;
        var ttip = document.getElementById('temptip'), tgl = document.getElementById('tgl'), tgd = document.getElementById('tgd'), tfig = tsvg.parentNode;
        // Pointer Events : couvre souris + tactile (tap/glisse) + stylet d'un seul jeu.
        function tShow(e) {
          var r = tsvg.getBoundingClientRect(), frac = (e.clientX - r.left) / r.width;
          if (frac < 0) frac = 0; if (frac > 1) frac = 1;
          var i = Math.round(frac * 23), t = year[i];
          if (t === null) { ttip.classList.remove('on'); tgl.setAttribute('opacity', '0'); tgd.setAttribute('opacity', '0'); return; }
          var gx = X(i), gy = Y(t), fr = tfig.getBoundingClientRect();
          tgl.setAttribute('x1', gx); tgl.setAttribute('x2', gx); tgl.setAttribute('opacity', '.4');
          tgd.setAttribute('cx', gx); tgd.setAttribute('cy', gy); tgd.setAttribute('opacity', '1');
          ttip.textContent = (i < 10 ? '0' : '') + i + ' h · ' + t.toFixed(1).replace('.', ',') + ' °C';
          ttip.style.left = ((gx / W) * r.width + (r.left - fr.left)) + 'px';
          ttip.style.top = ((gy / H) * r.height + (r.top - fr.top)) + 'px';
          ttip.classList.add('on');
        }
        function tHide() { ttip.classList.remove('on'); tgl.setAttribute('opacity', '0'); tgd.setAttribute('opacity', '0'); }
        tsvg.addEventListener('pointerenter', tShow);
        tsvg.addEventListener('pointermove', tShow);
        tsvg.addEventListener('pointerleave', tHide);
        tsvg.addEventListener('pointercancel', tHide);
      }

      // ---- Horloge d'activité 24 h ----
      var D = BIRD_HOURS;
      var sr = SUNRISE_H, ss = SUNSET_H;
      var cx = 150, cy = 150, r0 = 52, rmax = 120, rRing = 132;
      var max = Math.max.apply(null, D.concat([1]));
      function pt(R, h) { var t = h / 24 * 2 * Math.PI; return [cx + R * Math.sin(t), cy - R * Math.cos(t)]; }
      function h2(n) { return (n < 10 ? '0' : '') + n; }
      var s = '';
      s += '<circle cx="150" cy="150" r="' + rRing + '" fill="none" stroke="#D8D2C6" stroke-width="6"/>';
      var p1 = pt(rRing, sr), p2 = pt(rRing, ss), large = (ss - sr) > 12 ? 1 : 0;
      s += '<path d="M ' + p1[0].toFixed(1) + ' ' + p1[1].toFixed(1) + ' A ' + rRing + ' ' + rRing + ' 0 ' + large + ' 1 ' + p2[0].toFixed(1) + ' ' + p2[1].toFixed(1) + '" fill="none" stroke="#9FB7B9" stroke-width="6"/>';
      [sr, ss].forEach(function (h) { var q = pt(rRing, h); s += '<circle cx="' + q[0].toFixed(1) + '" cy="' + q[1].toFixed(1) + '" r="3.4" fill="#3F6764"/>'; });
      for (var h = 0; h < 24; h++) {
        var len = (D[h] / max) * (rmax - r0), a = pt(r0, h), b = pt(r0 + len, h);
        s += '<line class="bar" data-i="' + h + '" x1="' + a[0].toFixed(1) + '" y1="' + a[1].toFixed(1) + '" x2="' + b[0].toFixed(1) + '" y2="' + b[1].toFixed(1) + '" stroke="#2B3736" stroke-width="5" stroke-linecap="round"/>';
      }
      for (var h = 0; h < 24; h++) {
        var c = pt(r0, h), d = pt(rmax, h);
        s += '<line class="barhit" data-h="' + h + '" data-n="' + D[h] + '" x1="' + c[0].toFixed(1) + '" y1="' + c[1].toFixed(1) + '" x2="' + d[0].toFixed(1) + '" y2="' + d[1].toFixed(1) + '" stroke="transparent" stroke-width="13" stroke-linecap="round" pointer-events="all"/>';
      }
      [[0, '00h'], [6, '06h'], [12, '12h'], [18, '18h']].forEach(function (o) {
        var q = pt(rRing + 18, o[0]);
        s += '<text x="' + q[0].toFixed(1) + '" y="' + (q[1] + 4).toFixed(1) + '" text-anchor="middle" font-family="Spectral,serif" font-size="11" fill="#6E766F">' + o[1] + '</text>';
      });
      // « pic du jour » : heure où D est max
      var peakIdx = 0; for (var k = 1; k < 24; k++) if (D[k] > D[peakIdx]) peakIdx = k;
      s += '<text x="150" y="145" text-anchor="middle" font-family="Fraunces,Georgia,serif" font-size="23" fill="#2B3736">' + h2(peakIdx) + ' h</text>';
      s += '<text x="150" y="163" text-anchor="middle" font-family="Spectral,serif" font-size="11" fill="#566260">pic du jour</text>';
      var clk = document.getElementById('clock');
      if (clk) {
        clk.innerHTML = s;
        var tip = document.getElementById('ctip'), wrapEl = clk.parentNode, bars = clk.querySelectorAll('.bar');
        clk.querySelectorAll('.barhit').forEach(function (hit) {
          var h = +hit.getAttribute('data-h'), n = +hit.getAttribute('data-n');
          function show(e) {
            var r = wrapEl.getBoundingClientRect();
            tip.textContent = h2(h) + '–' + h2((h + 1) % 24) + ' h : ' + n + (n > 1 ? ' observations' : ' observation');
            tip.style.left = (e.clientX - r.left) + 'px';
            tip.style.top = (e.clientY - r.top) + 'px';
            tip.classList.add('on');
            if (bars[h]) bars[h].setAttribute('stroke', '#3F6764');
          }
          function hide() { tip.classList.remove('on'); if (bars[h]) bars[h].setAttribute('stroke', '#2B3736'); }
          hit.addEventListener('pointerenter', show);
          hit.addEventListener('pointermove', show);
          hit.addEventListener('pointerleave', hide);
          hit.addEventListener('pointercancel', hide);
        });
      }

      // Bargraph Luminosité — tooltip custom au survol des barres
      var lbtip = document.getElementById('lbtip');
      if (lbtip) {
        var lbWrap = lbtip.parentNode;
        document.querySelectorAll('.luxbars rect[data-tip]').forEach(function (rect) {
          var msg = rect.getAttribute('data-tip');
          if (!msg) return;
          function show(e) {
            var r = lbWrap.getBoundingClientRect();
            lbtip.textContent = msg;
            lbtip.style.left = (e.clientX - r.left) + 'px';
            lbtip.style.top = (e.clientY - r.top) + 'px';
            lbtip.classList.add('on');
          }
          function hide() { lbtip.classList.remove('on'); }
          rect.addEventListener('pointerenter', show);
          rect.addEventListener('pointermove', show);
          rect.addEventListener('pointerleave', hide);
          rect.addEventListener('pointercancel', hide);
        });
      }

      // ---- Graphique 30 jours : observations (barres) + espèces (ligne), double échelle ----
      // Mobile (≤560px) : ~10 jours visibles, défilement horizontal jusqu'à j-30.
      var bsvg = document.getElementById('bsvg');
      if (bsvg && BIRD_SERIES && BIRD_SERIES.det.length > 1) {
        var BD = BIRD_SERIES.det, BS = BIRD_SERIES.spe, BL = BIRD_SERIES.labels, BN = BD.length;
        var bH = 170, bpadL = 8, bpadR = 8, bpadT = 14, bpadB = 20;
        var detMax = Math.ceil(Math.max.apply(null, BD.concat([1])) / 500) * 500;
        var speMax = Math.ceil(Math.max.apply(null, BS.concat([1])) / 10) * 10;
        var bsWrap = document.getElementById('bsscroll');
        var bstipWrap = bsvg.closest('.bswrap');
        var bstip = document.getElementById('bstip');
        var DAYS_VISIBLE = 10;
        var mq = window.matchMedia('(max-width:560px)');
        var lastMobile = null;

        function renderBseries() {
          var mobile = mq.matches;
          var cw = bsWrap.clientWidth || 660;
          // Largeur du repère : desktop = 660 (s'ajuste à 100 %) ; mobile = 10 jours/écran, scroll au-delà.
          var bW = (mobile && BN > DAYS_VISIBLE) ? Math.round((cw / DAYS_VISIBLE) * BN) : (mobile ? cw : 660);
          var slot = (bW - bpadL - bpadR) / BN, bw = Math.max(2, slot * 0.6);
          function bX(i) { return bpadL + slot * (i + 0.5); }
          function bYd(v) { return bpadT + (1 - v / detMax) * (bH - bpadT - bpadB); }
          function bYs(v) { return bpadT + (1 - v / speMax) * (bH - bpadT - bpadB); }
          var bg = '<rect x="0" y="0" width="' + bW + '" height="' + bH + '" fill="transparent" pointer-events="all"/>';
          for (var t = 0; t <= detMax; t += 1000) {
            bg += '<line x1="' + bpadL + '" y1="' + bYd(t).toFixed(1) + '" x2="' + (bW - bpadR) + '" y2="' + bYd(t).toFixed(1) + '" stroke="rgba(43,55,54,.10)" stroke-width="1"/>';
            bg += '<text x="' + bpadL + '" y="' + (bYd(t) - 3).toFixed(1) + '" font-family="Spectral,serif" font-size="10.5" fill="#6E766F">' + t.toLocaleString('fr-CA') + '</text>';
          }
          for (var ts = 0; ts <= speMax; ts += speMax / 2) {
            bg += '<text x="' + (bW - bpadR) + '" y="' + (bYs(ts) - 3).toFixed(1) + '" text-anchor="end" font-family="Spectral,serif" font-size="10.5" fill="#2B3736">' + ts + ' esp.</text>';
          }
          for (var i = 0; i < BN; i++) {
            var op = i === BN - 1 ? 0.7 : 0.42;
            bg += '<rect x="' + (bX(i) - bw / 2).toFixed(1) + '" y="' + bYd(BD[i]).toFixed(1) + '" width="' + bw.toFixed(1) + '" height="' + (bYd(0) - bYd(BD[i])).toFixed(1) + '" fill="#3F6764" fill-opacity="' + op + '"/>';
          }
          // pointe de la ligne = dernier jour ; l'icône d'oiseau s'y pose.
          var ex = bX(BN - 1), ey = bYs(BS[BN - 1]), bsz = 18, bsc = bsz / 24;
          // tracé des espèces, tronqué juste avant l'icône pour une séparation nette
          var bpts = [];
          for (var j = 0; j < BN - 1; j++) bpts.push(bX(j).toFixed(1) + ',' + bYs(BS[j]).toFixed(1));
          var pvx = bX(BN - 2), pvy = bYs(BS[BN - 2]);
          var ddx = ex - pvx, ddy = ey - pvy, dlen = Math.sqrt(ddx * ddx + ddy * ddy), dgap = bsz / 2 + 3;
          if (dlen > dgap + 1) bpts.push((ex - ddx / dlen * dgap).toFixed(1) + ',' + (ey - ddy / dlen * dgap).toFixed(1));
          bg += '<polyline fill="none" stroke="#2B3736" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" points="' + bpts.join(' ') + '"/>';
          // icône d'oiseau en vol au point du dernier jour (à la place qu'occupe
          // la pointe de la ligne) — pose la marque sur le point plutôt qu'au-dessus,
          // ce qui l'éloigne de l'étiquette d'axe du haut. Statique, sans animation.
          bg += '<g transform="translate(' + (ex - bsz / 2).toFixed(1) + ' ' + (ey - bsz / 2).toFixed(1) + ') scale(' + bsc.toFixed(3) + ')">' +
            '<path fill="#3F6764" d="m23 11.5l-3.05-1.13c-.26-1.15-.91-1.81-.91-1.81a4.19 4.19 0 0 0-5.93 0l-1.48 1.48L5 3c-1 4 0 8 2.45 11.22L2 19.5s8.89 2 14.07-2.05c2.76-2.16 3.38-3.42 3.77-4.75zm-5.29.22c-.39.39-1.03.39-1.42 0a.996.996 0 0 1 0-1.41c.39-.39 1.03-.39 1.42 0s.39 1.02 0 1.41"/>' +
            '</g>';
          // étiquettes de date : ~tous les 80 px, construites depuis la droite
          // pour que le jour le plus récent soit toujours étiqueté sans collision.
          var step = Math.max(1, Math.round(80 / slot));
          var bidx = [];
          for (var k = BN - 1; k >= 0; k -= step) bidx.unshift(k);
          for (var li = 0; li < bidx.length; li++) {
            var ix = bidx[li];
            var anc = ix === BN - 1 ? 'end' : ix === bidx[0] ? 'start' : 'middle';
            bg += '<text x="' + bX(ix).toFixed(1) + '" y="' + (bH - 5) + '" text-anchor="' + anc + '" font-family="Spectral,serif" font-size="10.5" fill="#6E766F">' + BL[ix] + '</text>';
          }
          bg += '<line id="bsgl" x1="0" y1="' + bpadT + '" x2="0" y2="' + (bH - bpadB) + '" stroke="#3F6764" stroke-width="1" opacity="0"/>';
          bsvg.setAttribute('viewBox', '0 0 ' + bW + ' ' + bH);
          if (mobile && BN > DAYS_VISIBLE) {
            bsvg.style.width = bW + 'px';   // taille naturelle (1:1) → scroll horizontal
            bsvg.style.height = bH + 'px';
          } else {
            bsvg.style.width = '';          // CSS width:100% reprend la main
            bsvg.style.height = '';
          }
          bsvg.innerHTML = bg;
          // au premier rendu mobile, partir du jour le plus récent (extrême droite)
          if (mobile && BN > DAYS_VISIBLE && lastMobile !== true) bsWrap.scrollLeft = bsWrap.scrollWidth;
          lastMobile = mobile;
          return { bX: bX, bW: bW };
        }

        var geom = renderBseries();
        bsvg.addEventListener('mousemove', function (e) {
          var r = bsvg.getBoundingClientRect(), frac = (e.clientX - r.left) / r.width;
          if (frac < 0) frac = 0; if (frac > 1) frac = 1;
          var i = Math.round(frac * (BN - 1));
          var bsgl = document.getElementById('bsgl');
          var gx = geom.bX(i), wr = bstipWrap.getBoundingClientRect();
          if (bsgl) { bsgl.setAttribute('x1', gx); bsgl.setAttribute('x2', gx); bsgl.setAttribute('opacity', '.35'); }
          bstip.innerHTML = BL[i] + ' · ' + BD[i].toLocaleString('fr-CA') + ' obs · ' + BS[i] + ' esp.';
          // position en pixels visibles, en tenant compte du défilement
          bstip.style.left = ((gx / geom.bW) * r.width + (r.left - wr.left)) + 'px';
          bstip.style.top = ((20 / bH) * r.height + (r.top - wr.top)) + 'px';
          bstip.classList.add('on');
        });
        bsvg.addEventListener('mouseleave', function () {
          bstip.classList.remove('on');
          var bsgl = document.getElementById('bsgl');
          if (bsgl) bsgl.setAttribute('opacity', '0');
        });
        var bsRaf;
        window.addEventListener('resize', function () {
          if (bsRaf) cancelAnimationFrame(bsRaf);
          bsRaf = requestAnimationFrame(function () { geom = renderBseries(); });
        });
      }

      // Bouton « Écouter » — les soundscapes BirdWeather du PUC sont captés très
      // bas (pics typiques −40 à −64 dB). On amplifie via Web Audio en normalisant
      // le pic de chaque extrait (~−3 dB), comme le fait le lecteur de BirdWeather.
      // <audio>.volume plafonne à 1.0 et ne permettrait pas ce gain.
      var bwActx = null, bwGain = null, bwWired = false;
      var bwGainCache = {};
      function bwEnsureGraph(audio) {
        if (bwWired) return;
        var AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return; // pas de Web Audio → lecture native (faible mais fonctionnelle)
        try {
          bwActx = new AC();
          var src = bwActx.createMediaElementSource(audio);
          bwGain = bwActx.createGain();
          bwGain.gain.value = 8; // gain de repli avant calcul de normalisation
          src.connect(bwGain);
          bwGain.connect(bwActx.destination);
          bwWired = true;
        } catch (e) { bwActx = null; bwGain = null; }
      }
      function bwNormalize(url) {
        if (!bwActx || !bwGain || !url) return;
        if (bwGainCache[url]) { bwGain.gain.value = bwGainCache[url]; return; }
        fetch(url).then(function (r) { return r.arrayBuffer(); })
          .then(function (buf) { return bwActx.decodeAudioData(buf); })
          .then(function (audioBuf) {
            var peak = 0;
            for (var ch = 0; ch < audioBuf.numberOfChannels; ch++) {
              var data = audioBuf.getChannelData(ch);
              for (var i = 0; i < data.length; i++) { var a = data[i] < 0 ? -data[i] : data[i]; if (a > peak) peak = a; }
            }
            if (peak > 0) {
              var g = Math.min(Math.max(0.7 / peak, 1), 4000); // normalise le pic à ~−3 dB
              bwGainCache[url] = g;
              bwGain.gain.value = g;
            }
          })
          .catch(function () { /* échec décodage → on garde le gain de repli */ });
      }
      // Lecteur custom : le bouton « Écouter » fait play/pause, barre de
      // progression cliquable + temps en charte, contrôles natifs supprimés.
      var pBtn = document.getElementById('listenBtn');
      var pAudio = document.getElementById('obsAudio');
      if (pBtn && pAudio) {
        var pwrap = document.getElementById('pwrap');
        var pbar = document.getElementById('pbar');
        var pfill = document.getElementById('pbarFill');
        var ptime = document.getElementById('ptime');
        var iPlay = pBtn.querySelector('.i-play');
        var iPause = pBtn.querySelector('.i-pause');
        var pLbl = pBtn.querySelector('.listen-lbl');
        var pLoaded = false;

        function pFmt(s) {
          if (!isFinite(s) || s < 0) s = 0;
          var m = Math.floor(s / 60), ss = Math.floor(s % 60);
          return m + ':' + (ss < 10 ? '0' : '') + ss;
        }
        function pSetPlaying(on) {
          pBtn.classList.toggle('playing', on);
          iPlay.hidden = on; iPause.hidden = !on;
          pLbl.textContent = on ? 'Pause' : 'Écouter';
        }
        function pRefresh() {
          var d = pAudio.duration || 0, t = pAudio.currentTime || 0;
          var pct = d ? (t / d) * 100 : 0;
          pfill.style.width = pct.toFixed(1) + '%';
          pbar.style.setProperty('--pos', pct.toFixed(1) + '%');
          pbar.setAttribute('aria-valuenow', Math.round(pct));
          ptime.innerHTML = pFmt(t) + ' / ' + pFmt(d);
        }
        function pSeek(clientX) {
          var r = pbar.getBoundingClientRect(), frac = (clientX - r.left) / r.width;
          frac = Math.max(0, Math.min(1, frac));
          if (pAudio.duration) pAudio.currentTime = frac * pAudio.duration;
        }

        pBtn.addEventListener('click', function () {
          if (!pLoaded) {
            pLoaded = true;
            pAudio.src = pBtn.dataset.audioSrc || '';
            pwrap.hidden = false;
            bwEnsureGraph(pAudio);
            bwNormalize(pBtn.dataset.audioSrc || '');
          }
          if (bwActx && bwActx.state === 'suspended') bwActx.resume();
          if (pAudio.paused) pAudio.play().catch(function () { }); else pAudio.pause();
        });
        pAudio.addEventListener('play', function () { pSetPlaying(true); });
        pAudio.addEventListener('pause', function () { pSetPlaying(false); });
        pAudio.addEventListener('ended', function () { pSetPlaying(false); pAudio.currentTime = 0; pRefresh(); });
        pAudio.addEventListener('loadedmetadata', pRefresh);
        pAudio.addEventListener('timeupdate', pRefresh);
        pbar.addEventListener('click', function (e) { pSeek(e.clientX); });
        pbar.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowRight' && pAudio.duration) { pAudio.currentTime = Math.min(pAudio.duration, pAudio.currentTime + 2); e.preventDefault(); }
          else if (e.key === 'ArrowLeft' && pAudio.duration) { pAudio.currentTime = Math.max(0, pAudio.currentTime - 2); e.preventDefault(); }
          else if (e.key === ' ' || e.key === 'Enter') { pBtn.click(); e.preventDefault(); }
        });
      }
    })();
  </script>
</Base>
