---
import Base from '@/layouts/Base.astro';
import {
  latestPublished,
  publishedDates,
  quoteById,
  skyEventsFor,
  topBirdsFor,
  totalSpeciesAndDetectionsFor,
  weatherFor,
} from '@/lib/queries';

const entry = await latestPublished();
const allDates = await publishedDates();
const previousDate = entry ? allDates.find((d) => d < entry.entry_date) : null;

const date = entry?.entry_date ?? null;
const [weather, birds, sky, totals] = date
  ? await Promise.all([
      weatherFor(date),
      topBirdsFor(date, 8),
      skyEventsFor(date),
      totalSpeciesAndDetectionsFor(date),
    ])
  : [null, [], [], { species: 0, detections: 0 }];

const quoteId = entry?.highlights?.fragment_quote_id ?? null;
const quote = quoteId ? await quoteById(quoteId) : null;

const bird = entry?.highlights?.bird_of_the_day ?? null;

// Mise en forme française des dates pour le bandeau (« Hier, samedi 23 mai »).
function frenchDateLine(iso: string): { hier: string; ed: string } {
  const d = new Date(`${iso}T12:00:00Z`);
  const long = new Intl.DateTimeFormat('fr-CA', {
    timeZone: 'America/Toronto',
    weekday: 'long',
    day: 'numeric',
    month: 'long',
  }).format(d);
  const year = d.getUTCFullYear();
  const startOfYear = Date.UTC(year, 0, 1);
  const doy = Math.floor((d.getTime() - startOfYear) / 86400000) + 1;
  return { hier: long, ed: `an ${year} · ${doy}ᵉ jour` };
}

const dateLine = date ? frenchDateLine(date) : null;

const titleLong = entry?.title ?? 'Almanach du Val des Loups';
const pageTitle = entry
  ? `${titleLong} — édition du ${date}`
  : 'Almanach du Val des Loups';

function paragraphs(md: string | null): string[] {
  if (!md) return [];
  return md.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);
}
const body = paragraphs(entry?.body_md ?? null);

function fmtTemp(n: number | null | undefined, digits = 1): string {
  return n === null || n === undefined ? '—' : `${n.toFixed(digits)} °C`;
}
function fmtMm(n: number | null | undefined): string {
  return n === null || n === undefined ? '—' : `${n.toFixed(1)} mm`;
}
function fmtWind(ms: number | null | undefined): string {
  if (ms === null || ms === undefined) return '—';
  const kmh = ms * 3.6;
  return `${kmh.toFixed(0)} km/h`;
}
function pct(v: number, max: number): number {
  return Math.max(0, Math.min(100, (v / max) * 100));
}
const luxNow = weather?.solar_rad_avg ?? null; // proxy pour la jauge brightness
const luxPct = luxNow !== null ? pct(luxNow, 1000) : 0; // 1000 W/m² ≈ plein soleil
---

<Base title={pageTitle} active="une">
  {entry === null ? (
    <header class="mast">
      <div class="kicker">
        <span>Pont couvert de Saint-Placide-de-Charlevoix</span>
        <span><a href="https://maps.app.goo.gl/im6WzdgPWXcfj9Nx5" target="_blank" rel="noopener">47,4° N · 70,6° O · 377 m</a></span>
      </div>
      <div class="titleline">
        <h1 class="title"><em>Aucune</em> édition publiée</h1>
      </div>
      <p class="condition">L'almanach attend sa première édition — `npm run daily` une fois la BD prête.</p>
    </header>
  ) : (
    <>
      <header class="mast rv" style="animation-delay:.02s">
        <div class="kicker">
          <span>Pont couvert de Saint-Placide-de-Charlevoix</span>
          <span><a href="https://maps.app.goo.gl/im6WzdgPWXcfj9Nx5" target="_blank" rel="noopener">47,4° N · 70,6° O · 377 m</a></span>
        </div>
        <div class="titleline">
          <h1 class="title"><em>Hier,</em> {dateLine?.hier}</h1>
          <span class="ed">{dateLine?.ed}</span>
        </div>
        {entry.summary && <p class="condition">{entry.summary}</p>}
      </header>

      <section class="blk rv billet" style="animation-delay:.08s">
        <div class="rubric">
          <svg class="orn" width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/><path fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" d="M6.5 17.5C10 14 13.5 10.5 17 7"/></svg>
          <h2>Billet</h2><span class="line"></span>
        </div>
        {body.map((p, i) => (
          <p class={i === 0 ? 'drop' : ''}>{p}</p>
        ))}
        {previousDate && (
          <p class="more">
            <a href={`/archives/${previousDate}`}>lire les éditions précédentes →</a>
          </p>
        )}
      </section>

      {bird && (
        <section class="blk rv" style="animation-delay:.14s">
          <div class="rubric">
            <svg class="orn" width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/><path fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" d="M6.5 17.5C10 14 13.5 10.5 17 7"/></svg>
            <h2>Observation du jour</h2><span class="line"></span>
            <span class="src"><a href="https://app.birdweather.com/stations/6670">BirdWeather PUC</a></span>
          </div>
          <div class="obs">
            <div class="photo">
              {/* TODO(image-ref) : image de référence externe licenciée (Wikimedia/iNaturalist), pas d'archive locale. */}
              <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#6E766F" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7h.01M3.4 18c-.6-1.1-.9-2.4-.9-3.7C2.5 9.2 6 5.5 10.5 5.5c3.8 0 6.3 2.4 7 5.5l1.5 1.2c.3.2.5.5.5.9 0 .5-.4.9-.9.9H16l-2 6.5-3-3.5-2 2.5c-2.8 0-4.2-2-5.6-1.5Z"/></svg>
              <span class="cap">image de référence</span>
            </div>
            <div>
              <div class="sp">{bird.taxon_common ?? bird.taxon_scientific ?? '—'}</div>
              {bird.taxon_scientific && bird.taxon_common && (
                <div class="lat">{bird.taxon_scientific}</div>
              )}
              <div class="meta">
                {bird.observed_at && (
                  <span>entendue à {new Intl.DateTimeFormat('fr-CA', { timeZone: 'America/Toronto', hour: '2-digit', minute: '2-digit' }).format(new Date(bird.observed_at))}</span>
                )}
                {bird.confidence !== null && bird.confidence !== undefined && (
                  <span class="pill">confiance {Math.round(bird.confidence * 100)}&nbsp;%</span>
                )}
              </div>
              {bird.media_url && (
                <>
                  <button class="listen" type="button" aria-expanded="false" data-audio-src={bird.media_url}>
                    <svg width="11" height="11" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8 5v14l11-7z"/></svg>Écouter
                  </button>
                  <audio class="obsaudio" controls preload="none" hidden></audio>
                </>
              )}
            </div>
          </div>
        </section>
      )}

      {sky.length > 0 && (
        <section class="blk rv" style="animation-delay:.20s">
          <div class="rubric">
            <svg class="orn" width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/><path fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" d="M6.5 17.5C10 14 13.5 10.5 17 7"/></svg>
            <h2>Le ciel ce soir</h2><span class="line"></span>
          </div>
          <div class="sky">
            {sky.filter((s) => s.notable || s.category === 'twilight' || s.category === 'moon').slice(0, 4).map((s) => (
              <span class="it">{s.title}</span>
            ))}
          </div>
          {sky.find((s) => s.propice_a) && (
            <p class="propice">{sky.find((s) => s.propice_a)?.propice_a}</p>
          )}
        </section>
      )}

      <section class="blk rv" style="animation-delay:.26s">
        <div class="rubric">
          <svg class="orn" width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/><path fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" d="M6.5 17.5C10 14 13.5 10.5 17 7"/></svg>
          <h2>La mesure du jour</h2><span class="line"></span>
          <span class="src">Tempest 41129</span>
        </div>
        <div class="stats">
          <div class="stat">
            <div class="k">Température</div>
            <div class="v">{fmtTemp(weather?.air_temp_avg ?? null)}</div>
            <div class="sub">min {fmtTemp(weather?.air_temp_min ?? null, 0)} · max {fmtTemp(weather?.air_temp_max ?? null, 0)}</div>
          </div>
          <div class="stat">
            <div class="k">Vent</div>
            <div class="v">{fmtWind(weather?.wind_gust_max ?? null)}</div>
            <div class="sub">rafale max</div>
          </div>
          <div class="stat">
            <div class="k">Pluie</div>
            <div class="v">{fmtMm(weather?.rain_day_final_mm ?? null)}</div>
            <div class="sub">total du jour</div>
          </div>
          <div class="stat">
            <div class="k">Foudre</div>
            <div class="v">{weather?.lightning_count_total ?? 0}</div>
            <div class="sub">éclair{(weather?.lightning_count_total ?? 0) === 1 ? '' : 's'} détecté{(weather?.lightning_count_total ?? 0) === 1 ? '' : 's'}</div>
          </div>
        </div>
        <div class="gauge">
          <div class="legendrow"><span><span class="sw" style="border-top-color:var(--teal)"></span>jauge de luminosité (proxy rayonnement solaire moyen)</span></div>
          <div class="trackwrap">
            <div class="track">
              <div class="fill" style={`width:${luxPct}%`}></div>
            </div>
          </div>
          <div class="ticks"><span>nuit</span><span>aube</span><span>milieu de jour</span><span>plein soleil</span></div>
        </div>
        {/* TODO(svg) : porter les composants visuels signature (courbe température année vs moyenne historique, horloge oiseaux 24 h) en SVG inline au build ; passe ultérieure. */}
      </section>

      <section class="blk rv" style="animation-delay:.32s">
        <div class="rubric">
          <svg class="orn" width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/><path fill="none" stroke="var(--paper)" stroke-width="1.4" stroke-linecap="round" d="M6.5 17.5C10 14 13.5 10.5 17 7"/></svg>
          <h2>Activités des oiseaux</h2><span class="line"></span>
          <span class="src"><a href="https://app.birdweather.com/stations/6670">BirdWeather</a> · sur 24&nbsp;h</span>
        </div>
        {/* TODO(svg) : horloge 24 h, à porter depuis le mockup en SVG inline au build. */}
        {birds.length > 0 && (
          <details class="drawer" open>
            <summary>Les oiseaux du jour — {totals.species} espèces, {totals.detections} détections <span class="chev">▾</span></summary>
            <div class="drawerbody">
              <div class="bgrid">
                {birds.map((b) => (
                  <div class="bird">
                    <div class="bphoto">
                      {/* TODO(image-ref) : photo de référence externe par espèce. */}
                      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#6E766F" stroke-width="1.3"><path d="M16 7h.01M3.4 18c-.6-1.1-.9-2.4-.9-3.7C2.5 9.2 6 5.5 10.5 5.5c3.8 0 6.3 2.4 7 5.5l1.5 1.2c.3.2.5.5.5.9 0 .5-.4.9-.9.9H16l-2 6.5-3-3.5-2 2.5c-2.8 0-4.2-2-5.6-1.5Z"/></svg>
                    </div>
                    <div class="bname">{b.taxon_common ?? b.taxon_scientific}<i>{b.taxon_scientific}</i></div>
                  </div>
                ))}
              </div>
            </div>
          </details>
        )}
      </section>

      {quote && (
        <section class="blk rv" style="animation-delay:.38s">
          <div class="rubric mini">
            <svg class="orn" width="13" height="13" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M4 20C4 11.7 10.7 5 19 5c.6 0 1 .4 1 1 0 8.3-6.7 15-15 15-.6 0-1-.4-1-1Z"/></svg>
            <h2>Fragment</h2><span class="line"></span>
          </div>
          <blockquote class="frag">
            « {quote.text} »
            <cite>{quote.author} — {quote.work}{quote.year ? `, ${quote.year}` : ''}</cite>
          </blockquote>
        </section>
      )}

      <footer>
        <div class="row">
          <span class="mv">Sources : <a href="https://tempestwx.com">Tempest</a>, <a href="https://app.birdweather.com">BirdWeather</a>, <a href="https://github.com/cosinekitty/astronomy">astronomy-engine</a>, <a href="https://services.swpc.noaa.gov">NOAA SWPC</a></span>
          <a href="/donnees">archives & données →</a>
        </div>
      </footer>
    </>
  )}

  <script>
    // Bouton « Écouter » : câblé à data-audio-src ; play/pause sans librairie.
    const btns = document.querySelectorAll<HTMLButtonElement>('.listen[data-audio-src]');
    for (const btn of btns) {
      btn.addEventListener('click', () => {
        const audio = btn.nextElementSibling as HTMLAudioElement | null;
        if (!audio) return;
        if (audio.hidden) {
          audio.hidden = false;
          audio.src = btn.dataset.audioSrc ?? '';
          audio.play().catch(() => undefined);
          btn.setAttribute('aria-expanded', 'true');
        } else if (audio.paused) {
          audio.play().catch(() => undefined);
        } else {
          audio.pause();
        }
      });
    }
  </script>
</Base>
