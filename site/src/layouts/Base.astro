---
import '@/styles/globals.css';
import TopBar from '@/components/TopBar.astro';

interface Props {
  title: string;
  active?: 'une' | 'archives' | 'a-propos';
}
const { title, active } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,400..500&family=Spectral:ital,wght@0,300;0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <TopBar active={active} />
    <div class="wrap">
      <slot />
    </div>
  </body>
</html>
