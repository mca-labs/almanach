---
interface Props {
  active?: 'une' | 'archives' | 'a-propos';
}
const { active } = Astro.props;
---

<div class="topbar">
  <div class="wrap">
    <span class="mark"><span class="leaf">&#10047;</span>&nbsp; Almanach du Val des Loups</span>
    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="topnav"
      aria-label="Ouvrir le menu"
    >
      <span></span><span></span><span></span>
    </button>
    <nav class="nav" id="topnav">
      <a class={active === 'une' ? 'on' : ''} href="/">Almanach</a>
      <a class={active === 'archives' ? 'on' : ''} href="/archives">Archives</a>
      <a class={active === 'a-propos' ? 'on' : ''} href="/a-propos">À propos</a>
    </nav>
  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = document.getElementById('topnav');
  if (toggle && nav) {
    const close = () => {
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Ouvrir le menu');
      nav.classList.remove('open');
    };
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      toggle.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu');
      nav.classList.toggle('open', !open);
    });
    nav.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>
