# Postgres (Railway en prod, local en dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/almanach

# Tempest — jeton perso depuis Settings → Data Authorizations
WEATHERFLOW_TOKEN=
WEATHERFLOW_STATION_ID=41129

# BirdWeather — pas de jeton requis pour la lecture publique (validé 2026-05-23)
# Laisser commenté ; à activer seulement si un endpoint privé est ajouté plus tard.
# BIRDWEATHER_TOKEN=
BIRDWEATHER_STATION_ID=6670

# Anthropic — pour la synthèse du billet
ANTHROPIC_API_KEY=

# Open-Meteo — couverture nuageuse uniquement (pas de clé)
OPENMETEO_BASE=https://api.open-meteo.com/v1

# NOAA SWPC — aurores
NOAA_SWPC_BASE=https://services.swpc.noaa.gov

# Hook de rebuild du site (Railway / Netlify) — optionnel
SITE_DEPLOY_HOOK_URL=

# Géolocalisation du pont couvert (verbatim depuis Tempest + spec)
OBS_LAT=47.40744
OBS_LON=-70.61846
OBS_ELEV_M=377
TZ=America/Toronto

# Cron : 1 5 * * * UTC = 00:01 EST (hiver) / 01:01 EDT (été)
# Sémantique : « édition décrivant la veille », toujours post-minuit local.
