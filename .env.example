# Open-Meteo — couverture nuageuse uniquement (pas de clé). Défaut OK.
OPENMETEO_BASE=https://api.open-meteo.com/v1

# NOAA SWPC — aurores. Défaut OK.
NOAA_SWPC_BASE=https://services.swpc.noaa.gov

# Géolocalisation du pont couvert (déjà en dur dans src/almanac.ts, surcharge optionnelle)
OBS_LAT=47.40744
OBS_LON=-70.61846
OBS_ELEV_M=377
TZ=America/Toronto
