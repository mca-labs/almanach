{
  "name": "almanach",
  "version": "0.1.0",
  "private": true,
  "description": "Almanach du Val des Loups — observatoire nature d'un seul lieu, édition quotidienne figée.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "daily": "tsx src/cli.ts",
    "site:dev": "astro dev --root site",
    "site:build": "astro build --root site",
    "site:check": "astro check --root site",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "astro": "^6.4.2",
    "astronomy-engine": "^2.1.19"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
